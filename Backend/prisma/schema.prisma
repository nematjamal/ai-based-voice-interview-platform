generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(uuid())
  name             String
  email            String             @unique
  password         String
  role             Role               @default(USER)
  image            String?
  ResumeUrl        String?
  extractedText    String?            @db.Text
  atsScore         Int?
  resumeSkills     String[]
  resumeProjects   String[]
  resumeExperience String[]
  candidateLevel   String?
  recommendedRoles String?
  resumeStrengths  String[]
  resumeWeaknesses String[]
  isVerified       Boolean            @default(false)
  otp              String?
  otpExpiry        DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime           @default(now())
  attempts         InterviewAttempt[]
  responses        UserResponse[]
  notifications    Notification[]
  achievements     Achievement[]
  codingSubmits    CodingSubmission[]
  aiAnalysis       AIAnalysis[]
  aiScores         AIScore[]
  aiRoadmaps       AIRoadmap[]
  aiChats          AIChat[]
  voiceSessions    VoiceSession[]
  recommendations  AIRecommendation[]
}

model InterviewCategory {
  id          String      @id @default(uuid())
  name        String
  description String?
  interviews  Interview[]
  questions   Question[]
}

model Interview {
  id          String             @id @default(uuid())
  title       String
  description String?
  level       String
  duration    Int?
  categoryId  String
  category    InterviewCategory  @relation(fields: [categoryId], references: [id])
  attempts    InterviewAttempt[]
  questions   Question[]
}

model Question {
  id             String            @id @default(uuid())
  question       String
  expectedAnswer String?
  difficulty     Difficulty
  interviewId    String?
  categoryId     String
  createdAt      DateTime          @default(now())
  interview      Interview?        @relation(fields: [interviewId], references: [id])
  category       InterviewCategory @relation(fields: [categoryId], references: [id])
}

model InterviewAttempt {
  id                  String              @id @default(uuid())
  userId              String
  interviewId         String
  status              AttemptStatus       @default(STARTED)
  overallScore        Float?
  technicalScore      Float?
  communicationScore  Float?
  confidenceScore     Float?
  grammarScore        Float?
  problemSolvingScore Float?
  rating              InterviewRating?
  feedback            String?
  strengths           String[]
  weaknesses          String[]
  improvementTips     String[]
  isResumeBased       Boolean             @default(false)
  resumeContext       String?
  startedAt           DateTime            @default(now())
  completedAt         DateTime?
  user                User                @relation(fields: [userId], references: [id])
  interview           Interview           @relation(fields: [interviewId], references: [id])
  previousAttemptId   String?
  previousAttempt     InterviewAttempt?   @relation("RetryRelation", fields: [previousAttemptId], references: [id])
  nextAttempts        InterviewAttempt[]  @relation("RetryRelation")
  responses           UserResponse[]
  aiScore             AIScore?            @relation("AttemptAIScore")
  aiAnalysis          AIAnalysis?         @relation("AttemptAIAnalysis")
  voiceSessions       VoiceSession[]
  generatedQuestions  GeneratedQuestion[]
  aiChats             AIChat[]
}

model GeneratedQuestion {
  id             String           @id @default(uuid())
  attemptId      String
  question       String
  expectedAnswer String?
  difficulty     Difficulty
  source         String?
  skill          String?
  createdAt      DateTime         @default(now())
  attempt        InterviewAttempt @relation(fields: [attemptId], references: [id])
  responses      UserResponse[]
}

model UserResponse {
  id                  String            @id @default(uuid())
  userId              String
  attemptId           String
  generatedQuestionId String
  answer              String?
  audioUrl            String?
  technicalScore      Float?
  communicationScore  Float?
  aiFeedback          String?
  createdAt           DateTime          @default(now())
  user                User              @relation(fields: [userId], references: [id])
  attempt             InterviewAttempt  @relation(fields: [attemptId], references: [id])
  generatedQuestion   GeneratedQuestion @relation(fields: [generatedQuestionId], references: [id])
}

model AIAnalysis {
  id                     String           @id @default(uuid())
  userId                 String
  attemptId              String           @unique
  technicalAnalysis      String?
  communicationAnalysis  String?
  confidenceAnalysis     String?
  grammarAnalysis        String?
  problemSolvingAnalysis String?
  strengths              String[]
  weaknesses             String[]
  overallFeedback        String?
  improvementPlan        String?
  createdAt              DateTime         @default(now())
  user                   User             @relation(fields: [userId], references: [id])
  attempt                InterviewAttempt @relation("AttemptAIAnalysis", fields: [attemptId], references: [id])
}

model AIRoadmap {
  id                String   @id @default(uuid())
  userId            String
  title             String
  description       String?
  weakSkills        String[]
  suggestedSkills   String[]
  suggestedProjects String[]
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id])
}

model AIChat {
  id        String           @id @default(uuid())
  userId    String
  attemptId String
  role      String
  message   String
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
  attempt   InterviewAttempt @relation(fields: [attemptId], references: [id])
}

model VoiceSession {
  id            String           @id @default(uuid())
  userId        String
  attemptId     String
  audioUrl      String
  transcript    String?
  duration      Int?
  questionAsked String?
  createdAt     DateTime         @default(now())
  user          User             @relation(fields: [userId], references: [id])
  attempt       InterviewAttempt @relation(fields: [attemptId], references: [id])
}

model AIScore {
  id                  String           @id @default(uuid())
  userId              String
  attemptId           String           @unique
  technicalScore      Float?
  communicationScore  Float?
  confidenceScore     Float?
  grammarScore        Float?
  problemSolvingScore Float?
  createdAt           DateTime         @default(now())
  user                User             @relation(fields: [userId], references: [id])
  attempt             InterviewAttempt @relation("AttemptAIScore", fields: [attemptId], references: [id])
}

model AIRecommendation {
  id             String   @id @default(uuid())
  userId         String
  type           String
  recommendation String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}

model CodingChallenge {
  id          String             @id @default(uuid())
  title       String
  description String?
  difficulty  Difficulty
  starterCode String?
  solution    String?
  testCases   Json
  createdAt   DateTime           @default(now())
  submissions CodingSubmission[]
}

model CodingSubmission {
  id          String          @id @default(uuid())
  userId      String
  code        String
  language    String
  challengeId String
  score       Float?
  feedback    String?
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id])
  challenge   CodingChallenge @relation(fields: [challengeId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  badge       String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum InterviewRating {
  POOR
  AVERAGE
  GOOD
  EXCELLENT
}

enum AttemptStatus {
  STARTED
  COMPLETED
  IN_PROGRESS
  CANCELED
}
